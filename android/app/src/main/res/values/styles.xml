<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window as soon as the process has started.
         This theme determines the app's initial visual look. -->
    <style name="LaunchTheme" parent="@android:style/Theme.DeviceDefault.Light.NoActionBar">
        <!-- Show a splash screen on the activity. -->
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <!-- Theme applied to the Android Window after the Flutter view is launched -->
    <style name="NormalTheme" parent="@android:style/Theme.DeviceDefault.Light.NoActionBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
